# Скопируйте этот файл в ~/.config/cc-providers/keys.env и впишите свои ключи.
# Этот файл НЕ коммитить и НЕ класть в репозитории. Права: chmod 600.
#
# Имена переменных должны совпадать с "auth_token_env" в providers.toml.

# z.ai (GLM)
export Z_AI_API_KEY=""

# DeepSeek
export DEEPSEEK_API_KEY=""

# Anthropic (необязательно).
# Обычно достаточно `claude login`. Если хотите ключом вместо логина —
# раскомментируйте и впишите:
# export ANTHROPIC_API_KEY=""
